    pathActive=false
    local c=lp.Character local hum=c and c:FindFirstChildOfClass("Humanoid")
    if hum then hum:MoveTo(lp.Character:FindFirstChild("HumanoidRootPart") and lp.Character.HumanoidRootPart.Position or Vector3.zero) end
end
