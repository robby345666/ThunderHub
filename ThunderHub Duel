            dragActive=true hasMoved=false
            dragStart=i.Position startPos=pill.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if dragActive and (i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch) then
            local d=i.Position-dragStart
            if d.Magnitude>5 then
                hasMoved=true
                pill.Position=UDim2.new(startPos.X.Scale,startPos.X.Offset+d.X,startPos.Y.Scale,startPos.Y.Offset+d.Y)
            end
        end
    end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
            dragActive=false
        end
    end)

    local clickCb=nil
    pill.MouseButton1Click:Connect(function()
        if hasMoved then hasMoved=false return end
        if clickCb then clickCb() end
    end)

    local function activate(on)
        TweenService:Create(pill,twS,{BackgroundColor3=on and Color3.fromRGB(20,55,20) or Color3.fromRGB(12,12,20)}):Play()
        TweenService:Create(lb,twS,{TextColor3=on and Color3.fromRGB(80,230,100) or Color3.fromRGB(200,200,230)}):Play()
        TweenService:Create(sk,twS,{Color=on and Color3.fromRGB(60,210,80) or Color3.fromRGB(80,50,200)}):Play()
        TweenService:Create(dot,twS,{BackgroundColor3=on and Color3.fromRGB(60,210,80) or Color3.fromRGB(40,40,45)}):Play()
    end

    local function setClick(fn) clickCb=fn end
    return pill, activate, setClick
end

