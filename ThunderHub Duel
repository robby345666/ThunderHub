--  SPEED SYSTEM  (BodyVelocity — never touches WalkSpeed, undetectable)
-- ════════════════════════════════════
local speedBV = nil

local function applySpeed()
    -- remove old
    if speedBV then speedBV:Destroy() speedBV=nil end
    if not cfg.CarrySpeed then return end
    local c = lp.Character if not c then return end
    local hrp = c:FindFirstChild("HumanoidRootPart") if not hrp then return end
    local bv = Instance.new("BodyVelocity")
    bv.Name = "TH_SpeedBV"
    bv.MaxForce = Vector3.new(1e5, 0, 1e5) -- horizontal only, don't affect jumping
    bv.Velocity = Vector3.zero
    bv.P = 1e4
    bv.Parent = hrp
    speedBV = bv
end

lp.CharacterAdded:Connect(function(c)
    speedBV = nil
    task.wait(1)
    applySpeed()
end)

-- Every heartbeat update the velocity direction
RunService.Heartbeat:Connect(function()
    if not cfg.CarrySpeed or not speedBV or not speedBV.Parent then
        if speedBV then speedBV:Destroy() speedBV=nil end
        return
    end
    local c = lp.Character if not c then return end
    local hum = c:FindFirstChild("Humanoid") if not hum then return end
    local hrp = c:FindFirstChild("HumanoidRootPart") if not hrp then return end
    local dir = hum.MoveDirection
    if dir.Magnitude > 0.1 then
        speedBV.Velocity = dir * cfg.CarrySpeedValue
    else
        speedBV.Velocity = Vector3.zero
    end
end)

