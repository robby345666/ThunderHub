-- ── Ragdoll TP ──
-- Duel bases:  Base A (low Z  ~11-25)   Base B (high Z ~95-112)
-- Rule: if you're near base B (high Z) when ragdolled → TP to base A and vice versa
local DUEL_BASE_A = Vector3.new(-473, -5, 18)   -- left/low-Z base safe spot
local DUEL_BASE_B = Vector3.new(-473, -5, 102)  -- right/high-Z base safe spot
local DUEL_Z_MID  = 55  -- anything below this Z = base A side, above = base B side

local ragTPConn = nil
local function enableRagTP()
    if ragTPConn then return end
    ragTPConn = RunService.Heartbeat:Connect(function()
        if not cfg.RagdollTP then return end
        local c = lp.Character if not c then return end
        local hum = c:FindFirstChildOfClass("Humanoid") if not hum then return end
        local hrp = c:FindFirstChild("HumanoidRootPart") if not hrp then return end
        local state = hum:GetState()
        -- detect ragdoll / hit state
        local isRag = (state == Enum.HumanoidStateType.Physics
                    or state == Enum.HumanoidStateType.Ragdoll
                    or state == Enum.HumanoidStateType.FallingDown)
        -- also check RagdollEndTime attribute games sometimes use
        if not isRag then
            local et = lp:GetAttribute("RagdollEndTime")
            if et then local sn=0 pcall(function() sn=workspace:GetServerTimeNow() end) if (et-sn)>0 then isRag=true end end
        end
        if not isRag then return end
        -- decide which base to TP to based on current Z position
        local myZ = hrp.Position.Z
        local dest = myZ >= DUEL_Z_MID and DUEL_BASE_A or DUEL_BASE_B
        -- teleport
        pcall(function()
            hrp.CFrame = CFrame.new(dest)
        end)
        -- force out of ragdoll state
        pcall(function() hum:ChangeState(Enum.HumanoidStateType.GettingUp) end)
        pcall(function() hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false) end)
        task.wait(0.1)
        pcall(function() hum:SetStateEnabled(Enum.HumanoidStateType.FallingDown, true) end)
        pcall(function() hum:ChangeState(Enum.HumanoidStateType.Running) end)
        -- small cooldown so we don't TP every frame while ragdolled
        task.wait(0.5)
    end)
end
local function disableRagTP()
    if ragTPConn then ragTPConn:Disconnect() ragTPConn=nil end
end

