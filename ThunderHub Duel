local duelPath={} local duelIdx=1 local duelMoving=false local duelConn=nil local duelPend=false
local function startDuel()
    local c=lp.Character if not c then return end
    local hum=c:FindFirstChildOfClass("Humanoid") if not hum then return end
    local root=c:FindFirstChild("HumanoidRootPart") if not root then return end
    duelMoving=true duelPend=false
    if (root.Position-Vector3.new(-475,-7,96)).Magnitude>(root.Position-Vector3.new(-474,-7,23)).Magnitude then
        duelPath={{position=Vector3.new(-475,-7,96)},{position=Vector3.new(-483,-5,95)},{position=Vector3.new(-487,-5,95)},{position=Vector3.new(-492,-5,95)},{position=Vector3.new(-473,-7,95)},{position=Vector3.new(-473,-7,11)}}
    else
        duelPath={{position=Vector3.new(-474,-7,23)},{position=Vector3.new(-484,-5,24)},{position=Vector3.new(-488,-5,24)},{position=Vector3.new(-493,-5,25)},{position=Vector3.new(-473,-7,25)},{position=Vector3.new(-474,-7,112)}}
    end
    duelIdx=1
    if duelConn then duelConn:Disconnect() end
    duelConn=RunService.Stepped:Connect(function()
        if not cfg.AutoDuel or not duelMoving then return end
        local ch=lp.Character local h=ch and ch:FindFirstChildOfClass("Humanoid") if not h then return end
        local wp=duelPath[duelIdx] if not wp then duelMoving=false return end
        local r=ch:FindFirstChild("HumanoidRootPart") if not r then return end
        local dist=(r.Position-wp.position).Magnitude
        local stopDist=duelIdx==#duelPath and 1.5 or 3
        if dist<stopDist then
            if duelIdx==#duelPath then
                h:MoveTo(wp.position)
                if not duelPend then duelPend=true task.delay(0.8,function() if not cfg.AutoDuel then return end duelIdx=1 duelPend=false end) end
            else duelIdx=duelIdx+1 end
        else
            h:MoveTo(wp.position)
        end
    end)
end
local function stopDuel()
    duelMoving=false duelPend=false
    if duelConn then duelConn:Disconnect() duelConn=nil end
end

