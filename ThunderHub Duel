local function runPath(sp)
    local c=lp.Character or lp.CharacterAdded:Wait()
    local hum=c:WaitForChild("Humanoid")
    local hrp=c:WaitForChild("HumanoidRootPart")
    for i,p in ipairs(sp) do
        if not pathActive then return end
        hum:MoveTo(p.pos)
        -- wait until close enough or timeout
        local t=0
        repeat task.wait(0.05) t=t+0.05
            local dist=(hrp.Position-p.pos).Magnitude
            if dist<3 then break end
        until not pathActive or t>4
        if i==2 then task.wait(0.2) else task.wait(0.05) end
    end
end
local function startPath(sp) pathActive=true task.spawn(function() while pathActive do runPath(sp) task.wait(0.1) end end) end
